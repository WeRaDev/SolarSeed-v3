    "@nextcloud/initial-state": "^2.2.0",
    "@nextcloud/l10n": "^3.1.0",
    "@nextcloud/moment": "^1.3.1",
    "@nextcloud/router": "^3.0.1",
    "@nextcloud/vue": "^8.11.0",
    "@vue-leaflet/vue-leaflet": "^0.10.1",
    "ajv": "^8.17.1",
    "axios": "^1.13.2",
    "chart.js": "^3.9.1",
    "leaflet": "^1.9.4",
    "linkifyjs": "^4.3.2",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-chartjs": "^4.1.2",
    "vue-material-design-icons": "^5.3.1",
    "vue-router": "^4.3.0"
