    "stylelint:fix": "stylelint src/**/*.scss src/**/*.vue --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/WeRaDev/FilantropiaSolar.git"
  },
  "keywords": [
