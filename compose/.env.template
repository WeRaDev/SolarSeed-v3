# Copy this file to compose/.env and replace all CHANGE_ME_* values.
# Never commit real secrets.

# General
TZ=UTC

# === PostgreSQL (House) ===
POSTGRES_DB=cityoflight
POSTGRES_USER=citydb
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# === Rundeck (Factory) ===
RUNDECK_ADMIN_PASSWORD=CHANGE_ME_RUNDECK_ADMIN_PASSWORD
RUNDECK_GRAILS_URL=http://localhost:4440

# === Nextcloud AIO (Fortress) ===
NEXTCLOUD_DATADIR=/data/nextcloud
APACHE_PORT=8080
APACHE_IP_BINDING=0.0.0.0
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGE_ME_NEXTCLOUD_ADMIN_PASSWORD

# === Prometheus / Alertmanager (Library) ===
PROMETHEUS_RETENTION=30d
ALERTMANAGER_WEBHOOK_URL=http://spirit:9105/webhook/prometheus

# === Spirit (Agent/Brain) ===
SPIRIT_NAME=city_spirit_wera_ss_pt_sn_1
SPIRIT_PORT=9105
SPIRIT_HEARTBEAT_SECONDS=300
SPIRIT_LOG_LEVEL=info
SPIRIT_LLM_ENABLED=false
SPIRIT_LLM_ENDPOINT=http://llama-cpp:8081
SPIRIT_LLM_TIMEOUT=60
SPIRIT_LLM_MAX_TOKENS=512
# Comma-separated HTTP probes for services without Prometheus metrics
# Format: name=url,name=url
SPIRIT_HTTP_PROBES=nextcloud=http://filantropia-nextcloud:80

# === OpenFang (Persona Layer) ===
OPENFANG_REF=v0.3.11
OPENFANG_LOG_LEVEL=info
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=

# === llama.cpp (University, optional) ===
LLAMA_MODEL=/models/qwen3-4b-q5_k_m.gguf
LLAMA_THREADS=8
LLAMA_CTX_SIZE=4096
