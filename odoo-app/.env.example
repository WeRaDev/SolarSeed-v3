# Versions
ODOO_VERSION=19.0
ODOO_DB_IMAGE=pgvector/pgvector:pg16

# Odoo Enterprise subscription (custom edition)
# Set this to activate Enterprise features after addons are deployed.
ODOO_ENTERPRISE_CODE=M240830172487565

# Exposed ports on host (bind loopback by default; publish to tailnet via tailscale serve)
ODOO_BIND_HOST=127.0.0.1
ODOO_HTTP_PORT=8069
ODOO_LONGPOLL_PORT=8072

# PostgreSQL credentials used by Odoo
ODOO_DB_NAME=wera
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=change-this-odoo-db-password
# Restrict Odoo to the restored database name
ODOO_DB_FILTER=^wera$

# Keep demo data for learning by default (set to all to disable demo data)
ODOO_WITHOUT_DEMO=False
