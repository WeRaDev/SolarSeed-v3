# Versions
ODOO_VERSION=18.0
POSTGRES_VERSION=15

# Exposed ports on host
ODOO_HTTP_PORT=8069
ODOO_LONGPOLL_PORT=8072

# PostgreSQL credentials used by Odoo
ODOO_DB_NAME=postgres
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=change-this-odoo-db-password

# Restrict Odoo to the learning database name
ODOO_DB_FILTER=^odoo_lab$

# Keep demo data for learning by default (set to all to disable demo data)
ODOO_WITHOUT_DEMO=False
